# Copia este archivo a .env y rellena tus tokens. Nunca subas .env al repo.

# Hugging Face (https://huggingface.co/settings/tokens), permiso de escritura
HF_TOKEN=

# Weights & Biases (https://wandb.ai/authorize)
WANDB_API_KEY=

# Cloudflare R2 (S3 API). Crea un token de API en R2.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Azure ADLS Gen2 (capa lakehouse). Access key de la storage account actaslake25067
# (Portal > Storage account > Access keys). Solo se necesita con LAKEHOUSE_DESTINO=adls.
AZURE_STORAGE_ACCOUNT_KEY=

# Destino de escritura del lakehouse: local | adls | ambos (default: local).
LAKEHOUSE_DESTINO=local

# Google Sheets (export de marts gold a Looker Studio). Ruta al JSON de la service
# account con permiso de edicion sobre el spreadsheet destino. Opcional (Fase D).
GOOGLE_SHEETS_SA_JSON=
