# Copia este archivo a .env y rellena tus tokens. Nunca subas .env al repo.

# Hugging Face (https://huggingface.co/settings/tokens), permiso de escritura
HF_TOKEN=

# Weights & Biases (https://wandb.ai/authorize)
WANDB_API_KEY=

# Cloudflare R2 (S3 API). Crea un token de API en R2.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
